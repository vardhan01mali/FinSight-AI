# FinSight AI - Backend Environment Configuration Template

# Groq API Key (Obtain from https://console.groq.com)
GROQ_API_KEY=

# AI Provider (groq or ollama)
AI_PROVIDER=groq

# Database URL
# Development: sqlite:///./finsight.db
# Production: postgresql://username:password@hostname:5432/dbname
DATABASE_URL=sqlite:///./finsight.db

# JWT Secret Key for Session Authentication
# Generate a secure key using: openssl rand -hex 32
JWT_SECRET=supersecretjwtkeyforfinsightai1234567890

# ChromaDB Vector Storage Path
CHROMA_PATH=./chroma_db

# Allowed CORS Origins (comma-separated, no trailing slashes)
# E.g., http://localhost:5173
ALLOWED_ORIGINS=http://localhost:5173

# File size limits in bytes
# 20MB (20971520 bytes) for documents, 10MB (10485760 bytes) for images
MAX_FILE_SIZE=20971520
